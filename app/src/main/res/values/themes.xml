<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.AuthenticationBar87" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand_blue_light</item>
        <item name="colorPrimaryDark">@color/brand_blue_dark</item>
        <item name="colorSecondary">@color/brand_cyan</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnBackground">@color/text_primary_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
